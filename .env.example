# Wyoming port exposed to the host
WYOMING_PORT=10300

# Path to directory where GGML model files are stored
MODELS_DIR=./models

# whisper.cpp version to build
WHISPER_CPP_VERSION=1.7.4

# Model filename without "ggml-" prefix and ".bin" suffix
# The model file must exist at $MODELS_DIR/ggml-$WHISPER_MODEL.bin
# Download: https://huggingface.co/cstr/whisper-large-v3-turbo-german-ggml
WHISPER_MODEL=large-v3-q5_0

# Transcription language (ISO 639-1)
WHISPER_LANG=de

# Beam size — higher = more accurate but slower (1=greedy, 3=recommended with GPU)
WHISPER_BEAM_SIZE=3

# Audio context frames (30s = 3000, 7.5s = 768). Smaller = faster encoder.
# Sufficient for voice commands; use 3000 for long-form transcription.
WHISPER_AUDIO_CTX=768

# Initial prompt to bias the decoder toward domain vocabulary
# Include digit examples (50%, 20 Grad) so Whisper outputs numbers as digits
# rather than words ("fünf Prozent" → "5 Prozent")
WHISPER_PROMPT=Schalte das Licht an oder aus. Dimme die Lampe auf 50%. Fahre die Rolllaeden auf 0% 25% 50% 75% 100%. Stelle die Heizung auf 20 Grad. Oeffne und schliesse das Fenster.

# Host render group ID for /dev/dri access (run: getent group render | cut -d: -f3)
RENDER_GROUP_ID=109

# User/group to run containers as (run: id -u && id -g)
UID=0
GID=0

# Docker network that other services (Home Assistant, etc.) connect through
# Create with: docker network create wyoming-net
# (referenced as external in docker-compose.yaml)
